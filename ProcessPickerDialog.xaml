<Window x:Class="ScriptExecutorUI.ProcessPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Select Roblox Process" Height="300" Width="400"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="#1A1A1A" Foreground="#E0E0E0"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="ProcessListBox" Grid.Row="0" Background="#121212"
                 BorderThickness="0" FontFamily="Consolas" FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Pid}" Width="60" Foreground="#A020F0" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Name}" Foreground="#E0E0E0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="80" Height="30" Background="#333"
                    Foreground="#E0E0E0" Click="Cancel_Click" Cursor="Hand"/>
            <Button Content="Select" Width="80" Height="30" Background="#A020F0"
                    Foreground="White" Margin="10,0,0,0" Click="Select_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>