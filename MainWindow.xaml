<Window x:Class="ScriptExecutorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:local="clr-namespace:ScriptExecutorUI"
        Title="Script Executor" Height="700" Width="960"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="DeepDark" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="NeonPurple" Color="#A020F0"/>
        <SolidColorBrush x:Key="SoftWhite" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#00FF7F"/>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource SoftWhite}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="12"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#A020F0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="circle" Fill="#A020F0" Stroke="#D580FF" StrokeThickness="1.5"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="20"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccordionHeaderStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="{StaticResource SoftWhite}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter/>
                                <fa:IconBlock Grid.Column="1" Icon="Plus"
                                              Width="16" Height="16" Foreground="{StaticResource NeonPurple}"
                                              x:Name="icon"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="icon" Property="Icon" Value="Minus"/>
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border x:Name="MainBorder" Margin="5,10,10,10" Background="{StaticResource DeepDark}"
                CornerRadius="10" BorderBrush="#2A2A2A" BorderThickness="1" Grid.Column="1">
            <Border.Effect>
                <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="18"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="10,0,0,10" Padding="10">
                    <StackPanel Margin="0,15,0,0">
                        <TextBlock Text="EXECUTOR" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource NeonPurple}" Margin="10,0,0,15"/>
                        <ItemsControl x:Name="AccordionItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <ToggleButton Content="{Binding Name}"
                                                      Style="{StaticResource AccordionHeaderStyle}"
                                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                      Cursor="Hand"/>
                                        <ContentControl Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                        Margin="20,5,0,0">
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   Foreground="#C0C0C0" Margin="0,4"
                                                                   FontSize="12" Cursor="Hand"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ContentControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,0,0">
                        <Button x:Name="EditorTabBtn" Content="Editor" Width="80" Height="28"
                                Background="#222" Foreground="{StaticResource SoftWhite}"
                                FontWeight="SemiBold" Cursor="Hand"
                                Click="EditorTab_Click"/>
                        <Button x:Name="ConsoleTabBtn" Content="Console" Width="80" Height="28"
                                Background="#1A1A1A" Foreground="#888"
                                FontWeight="SemiBold" Cursor="Hand"
                                Click="ConsoleTab_Click"/>
                        <Button x:Name="ProcessSelectBtn" ToolTip="Choose Roblox process"
                                Style="{StaticResource GlowButtonStyle}" Margin="20,0,0,0"
                                Click="ProcessSelect_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Desktop" Width="14" Height="14"/>
                                <TextBlock x:Name="SelectedPidTxt" Text="No PID" Margin="6,0,0,0" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBox x:Name="CodeEditor" Grid.Row="1"
                             Background="#121212" Foreground="#E0E0E0"
                             BorderBrush="#2A2A2A" BorderThickness="0"
                             FontFamily="Consolas" FontSize="13"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             Padding="15,10"
                             Visibility="Visible"/>

                    <RichTextBox x:Name="ConsoleOutput" Grid.Row="1"
                                 Background="#121212" Foreground="#E0E0E0"
                                 BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="15,10"
                                 Visibility="Collapsed"/>

                    <Border Grid.Row="1" Background="#AA1A1A1A"
                            CornerRadius="8" Padding="8,4"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,12" MaxWidth="300">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" ShadowDepth="0" BlurRadius="10" Opacity="0.6"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Trash" Margin="3"
                                    Click="ClearEditor_Click">
                                <fa:IconBlock Icon="Trash" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Edit" Margin="3">
                                <fa:IconBlock Icon="Edit" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Paste" Margin="3">
                                <fa:IconBlock Icon="Paste" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Copy" Margin="3">
                                <fa:IconBlock Icon="Copy" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Execute"
                                    Margin="5,3,3,3" Click="ExecuteScript_Click">
                                <fa:IconBlock Icon="Play" Width="18" Height="18"
                                             Foreground="{StaticResource AccentGreen}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="0,10,10,0"
                        Width="60" Padding="0,15,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Code" Margin="0,8">
                            <fa:IconBlock Icon="Code" Width="20" Height="20"/>
                        </Button>
                        <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Search" Margin="0,8">
                            <fa:IconBlock Icon="Search" Width="20" Height="20"/>
                        </Button>
                        <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Settings" Margin="0,8">
                            <fa:IconBlock Icon="Gear" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Button x:Name="CloseButton" Style="{StaticResource CloseButtonStyle}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,15,15" Click="CloseButton_Click" Cursor="Hand" Grid.Column="1" Height="48" Width="48">
            <fa:IconBlock Icon="Times" Width="20" Height="20" Foreground="White"/>
        </Button>
    </Grid>
</Window>