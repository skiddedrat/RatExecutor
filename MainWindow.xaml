<Window x:Class="ScriptExecutorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:local="clr-namespace:ScriptExecutorUI"
        Title="Script Executor" Height="760" Width="1160"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="DeepDark" Color="#090B14"/>
        <SolidColorBrush x:Key="NeonPurple" Color="#A020F0"/>
        <SolidColorBrush x:Key="SoftWhite" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#63FFD2"/>
        <LinearGradientBrush x:Key="EditorAnimatedBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#101020" Offset="0.0"/>
            <GradientStop Color="#14142A" Offset="0.45"/>
            <GradientStop Color="#1F1235" Offset="1.0"/>
        </LinearGradientBrush>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C1C2C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource SoftWhite}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="buttonBorder" Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="#3A2A5A" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#2A2340"/>
                                <Setter TargetName="buttonBorder" Property="BorderBrush" Value="#A020F0"/>
                                <Setter TargetName="buttonBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="18" Opacity="0.85"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#351A5A"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#A020F0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="circle" Fill="#A020F0" Stroke="#D580FF" StrokeThickness="1.5"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="20"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccordionHeaderStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="{StaticResource SoftWhite}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter/>
                                <fa:IconBlock Grid.Column="1" Icon="Plus"
                                              Width="16" Height="16" Foreground="{StaticResource NeonPurple}"
                                              x:Name="icon"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="icon" Property="Icon" Value="Minus"/>
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Rectangle Fill="#080914"/>
        <Border Height="4" VerticalAlignment="Top" Margin="26,10,26,0" CornerRadius="2" Background="#A0A020F0"/>
        <Border Height="4" VerticalAlignment="Bottom" Margin="26,0,26,10" CornerRadius="2" Background="#A0D238FF"/>
        <Border x:Name="MainBorder" Margin="24" Background="Transparent"
                CornerRadius="22" BorderBrush="Transparent" BorderThickness="0">
            <Border.Effect>
                <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="18"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border Grid.Column="0" Margin="0,10,8,10" Background="#D0080B17" CornerRadius="18" Padding="18" BorderBrush="#553A3F65" BorderThickness="1.2">
                    <StackPanel Margin="0,15,0,0">
                        <TextBlock Text="RAT EXECUTOR" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource NeonPurple}" Margin="4,0,0,4"/>
                        <ItemsControl x:Name="AccordionItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <ToggleButton Content="{Binding Name}"
                                                      Style="{StaticResource AccordionHeaderStyle}"
                                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                      Cursor="Hand"/>
                                        <ContentControl Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                        Margin="20,5,0,0">
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   Foreground="#C0C0C0" Margin="0,4"
                                                                   FontSize="12" Cursor="Hand"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ContentControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- CENTRAL AREA -->
                <Grid Grid.Column="1" Margin="0,10,0,10" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tab Header -->
                    <Border Grid.Row="0" Margin="10,0,10,6" Background="#50161E35" CornerRadius="14" Padding="8,6" BorderBrush="#3B4B5E91" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="EditorTabBtn" Content="Editor" Width="80" Height="28"
                                Style="{StaticResource GlowButtonStyle}" Background="#2A2340" Foreground="{StaticResource SoftWhite}"
                                FontWeight="SemiBold" Cursor="Hand"
                                Click="EditorTab_Click"/>
                        <Button x:Name="ConsoleTabBtn" Content="Console" Width="80" Height="28"
                                Style="{StaticResource GlowButtonStyle}" Background="#1A1A1A" Foreground="#888"
                                FontWeight="SemiBold" Cursor="Hand"
                                Click="ConsoleTab_Click"/>
                        <!-- Process Selector + Connection Status -->
                        <Button x:Name="ProcessSelectBtn" ToolTip="Choose Roblox process"
                                Style="{StaticResource GlowButtonStyle}" Margin="20,0,0,0"
                                Click="ProcessSelect_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Desktop" Width="14" Height="14"/>
                                <TextBlock x:Name="SelectedPidTxt" Text="No PID" Margin="6,0,0,0" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="ConnectionStatusTxt" Text="Disconnected"
                                   Foreground="#888" FontSize="11" Margin="15,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    </Border>

                    <!-- Autocomplete Popup (floating above editor) -->
                    <Popup x:Name="SuggestionPopup" Grid.Row="1"
                           PlacementTarget="{Binding ElementName=CodeEditor}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True" PopupAnimation="Slide">
                        <Border Background="#1E1E1E" BorderBrush="#A020F0" BorderThickness="1"
                                CornerRadius="4" Padding="2">
                            <ListBox x:Name="SuggestionListBox"
                                     Background="Transparent" Foreground="#E0E0E0"
                                     BorderThickness="0" FontFamily="Consolas" FontSize="12"
                                     MaxHeight="200" MinWidth="180"
                                     MouseDoubleClick="SuggestionListBox_MouseDoubleClick"/>
                        </Border>
                    </Popup>

                    <!-- Editor / Console panels -->
                    <Border x:Name="EditorPanel" Grid.Row="2" CornerRadius="18" Margin="10,6,10,12" BorderBrush="#725595C4" BorderThickness="1.2">
                        <Border.Background>
                            <StaticResource ResourceKey="EditorAnimatedBackgroundBrush"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#6A2CB6" BlurRadius="20" ShadowDepth="0" Opacity="0.42"/>
                        </Border.Effect>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Background.(LinearGradientBrush.GradientStops)[0].Offset"
                                                         From="-0.15" To="0.35" Duration="0:0:8"/>
                                        <DoubleAnimation Storyboard.TargetProperty="Background.(LinearGradientBrush.GradientStops)[1].Offset"
                                                         From="0.3" To="0.8" Duration="0:0:8"/>
                                        <DoubleAnimation Storyboard.TargetProperty="Background.(LinearGradientBrush.GradientStops)[2].Offset"
                                                         From="0.9" To="1.15" Duration="0:0:8"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <TextBox x:Name="CodeEditor"
                                 Background="Transparent" Foreground="#F3F0FF"
                                 BorderThickness="0"
                                 FontFamily="Consolas" FontSize="13"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 Padding="15,10"
                                 Visibility="Visible"
                                 TextChanged="CodeEditor_TextChanged"
                                 PreviewTextInput="CodeEditor_PreviewTextInput"
                                 PreviewKeyDown="CodeEditor_PreviewKeyDown"/>
                    </Border>

                    <Border x:Name="ThemePanel" Grid.Row="2" Margin="10,6,10,12" Visibility="Collapsed"
                            Background="#D0101220" CornerRadius="18" BorderBrush="#5A607FA6" BorderThickness="1">
                        <StackPanel Margin="16">
                            <TextBlock Text="Theme Presets" Foreground="#E6E6FF" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="Pick a color style for the whole menu accent." Foreground="#9AA4C5" Margin="0,6,0,14"/>
                            <WrapPanel>
                                <Button Content="Default" Tag="Default" Style="{StaticResource GlowButtonStyle}" Margin="0,0,8,8" Click="ThemePreset_Click"/>
                                <Button Content="Ocean" Tag="Ocean" Style="{StaticResource GlowButtonStyle}" Margin="0,0,8,8" Click="ThemePreset_Click"/>
                                <Button Content="Sunset" Tag="Sunset" Style="{StaticResource GlowButtonStyle}" Margin="0,0,8,8" Click="ThemePreset_Click"/>
                                <Button Content="Forest" Tag="Forest" Style="{StaticResource GlowButtonStyle}" Margin="0,0,8,8" Click="ThemePreset_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <RichTextBox x:Name="ConsoleOutput" Grid.Row="2"
                                 Background="#121212" Foreground="#E0E0E0"
                                 BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="15,10"
                                 Visibility="Collapsed"/>

                    <!-- Floating action bar -->
                    <Border Grid.Row="2" Background="#CC101522"
                            CornerRadius="16" Padding="10,6"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,12" MaxWidth="300">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" ShadowDepth="0" BlurRadius="10" Opacity="0.6"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Trash" Margin="3"
                                    Click="ClearEditor_Click">
                                <fa:IconBlock Icon="Trash" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Clear Console" Margin="3" Click="ClearConsole_Click">
                                <fa:IconBlock Icon="Eraser" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Edit" Margin="3">
                                <fa:IconBlock Icon="Edit" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Paste" Margin="3">
                                <fa:IconBlock Icon="Paste" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Copy" Margin="3">
                                <fa:IconBlock Icon="Copy" Width="16" Height="16"/>
                            </Button>
                            <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Execute"
                                    Margin="5,3,3,3" Click="ExecuteScript_Click">
                                <fa:IconBlock Icon="Play" Width="18" Height="18"
                                             Foreground="{StaticResource AccentGreen}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RIGHT FLOATING TABS -->
                <StackPanel Grid.Column="2" Margin="14,120,12,0" VerticalAlignment="Top">
                    <Border Background="#C0080B17" CornerRadius="16" Padding="8" BorderBrush="#553A3F65" BorderThickness="1">
                        <StackPanel>
                    <Button x:Name="EditorTabBtnRight" Style="{StaticResource GlowButtonStyle}" ToolTip="Editor" Margin="0,0,0,10" Click="EditorTab_Click">
                        <fa:IconBlock Icon="Code" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="ConsoleTabBtnRight" Style="{StaticResource GlowButtonStyle}" ToolTip="Console" Margin="0,0,0,10" Click="ConsoleTab_Click">
                        <fa:IconBlock Icon="Terminal" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="SettingsTabBtn" Style="{StaticResource GlowButtonStyle}" ToolTip="Theme Settings" Click="SettingsTab_Click">
                        <fa:IconBlock Icon="Gear" Width="20" Height="20"/>
                    </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Button x:Name="CloseButton" Style="{StaticResource CloseButtonStyle}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,15,15" Click="CloseButton_Click" Cursor="Hand">
            <fa:IconBlock Icon="Times" Width="20" Height="20" Foreground="White"/>
        </Button>
    </Grid>
</Window>
