<Window x:Class="ScriptExecutorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:local="clr-namespace:ScriptExecutorUI"
        Title="Script Executor" Height="760" Width="1160"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="DeepDark" Color="#090B14"/>
        <SolidColorBrush x:Key="NeonPurple" Color="#A020F0"/>
        <SolidColorBrush x:Key="SoftWhite" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#63FFD2"/>
        <LinearGradientBrush x:Key="EditorAnimatedBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#101020" Offset="0.0"/>
            <GradientStop Color="#14142A" Offset="0.45"/>
            <GradientStop Color="#1F1235" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- ═══════════════════════════════════════════
             ABYSS REBORN
             MADE BY LUCID.ID
        ════════════════════════════════════════════ -->

        <!-- Shared thumb -->
        <Style x:Key="SlimThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="tb" Background="#55FFFFFF" CornerRadius="3" Margin="1.5"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="#99FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="#DDFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical scrollbar -->
        <Style x:Key="SlimScrollBarV" TargetType="ScrollBar">
            <Setter Property="Orientation"  Value="Vertical"/>
            <Setter Property="Width"        Value="6"/>
            <Setter Property="MinWidth"     Value="6"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" Height="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" Height="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Horizontal scrollbar -->
        <Style x:Key="SlimScrollBarH" TargetType="ScrollBar">
            <Setter Property="Orientation"  Value="Horizontal"/>
            <Setter Property="Height"       Value="6"/>
            <Setter Property="MinHeight"    Value="6"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Height="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                  Opacity="0" Width="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                                  Opacity="0" Width="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global implicit ScrollBar override so every ScrollViewer in the window gets slim bars.
             Checks Orientation and delegates to the correct keyed style above. -->
        <Style TargetType="ScrollBar">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width"    Value="6"/>
                    <Setter Property="MinWidth" Value="6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent" Width="6">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Height="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource SlimThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Height="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"    Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent" Height="6">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Width="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource SlimThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Width="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C1C2C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource SoftWhite}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="buttonBorder" Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="#3A2A5A" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#2A2340"/>
                                <Setter TargetName="buttonBorder" Property="BorderBrush" Value="#A020F0"/>
                                <Setter TargetName="buttonBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="18" Opacity="0.85"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#351A5A"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#A020F0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="circle" Fill="#A020F0" Stroke="#D580FF" StrokeThickness="1.5"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="20"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccordionHeaderStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="{StaticResource SoftWhite}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter/>
                                <fa:IconBlock Grid.Column="1" Icon="Plus"
                                              Width="16" Height="16" Foreground="{StaticResource NeonPurple}"
                                              x:Name="icon"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="icon" Property="Icon" Value="Minus"/>
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="12" CornerRadius="28" Background="#E0050710" BorderBrush="#70406195" BorderThickness="1.2">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.45"/>
            </Border.Effect>
        </Border>
        <Rectangle Fill="#080914" Margin="14" RadiusX="26" RadiusY="26"/>
        <Border Height="4" VerticalAlignment="Top" Margin="26,10,26,0" CornerRadius="2" Background="#A0A020F0"/>
        <Border Height="4" VerticalAlignment="Bottom" Margin="26,0,26,10" CornerRadius="2" Background="#A0D238FF"/>
        <Border x:Name="MainBorder" Margin="24" Background="Transparent"
                CornerRadius="22" BorderBrush="Transparent" BorderThickness="0">
            <Border.Effect>
                <DropShadowEffect Color="#A020F0" ShadowDepth="0" BlurRadius="18"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border Grid.Column="0" Margin="0,10,8,10" Background="#D0080B17" CornerRadius="18" Padding="18" BorderBrush="#553A3F65" BorderThickness="1.2">
                    <StackPanel Margin="0,15,0,0">
                        <TextBlock Text="Abyss Reborn" FontSize="24" FontWeight="Bold" Foreground="{StaticResource NeonPurple}" Margin="4,0,0,4"/>
                        <TextBlock Text="UI made by: lucid.id on Discord" Foreground="#D9CBFF" FontSize="12" Margin="4,0,0,14"/>
                        <Button Content="Import .lua / .txt" Style="{StaticResource GlowButtonStyle}" Margin="0,0,0,10" Click="ImportScriptFiles_Click"/>
                        <TextBlock Text="Saved Files" Foreground="#DCCBFF" FontFamily="Consolas" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ListBox x:Name="SavedFilesList"
                                 Background="#14161F" Foreground="#F0F0F0" BorderThickness="1" BorderBrush="#443A4A71"
                                 MinHeight="280" MouseDoubleClick="SavedFilesList_MouseDoubleClick"/>
                    </StackPanel>
                </Border>

                <!-- CENTRAL AREA -->
                <Grid Grid.Column="1" Margin="0,10,0,10" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tab Header -->
                    <Border Grid.Row="0" Margin="10,0,10,6" Background="#50161E35" CornerRadius="14" Padding="8,6" BorderBrush="#3B4B5E91" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="EditorTabBtn" Content="Editor" Width="80" Height="28"
                                Style="{StaticResource GlowButtonStyle}" Background="#2A2340" Foreground="{StaticResource SoftWhite}"
                                FontWeight="SemiBold" Cursor="Hand"
                                Click="EditorTab_Click"/>
                            <Button x:Name="ConsoleTabBtn" Content="Console" Width="80" Height="28"
                                Style="{StaticResource GlowButtonStyle}" Background="#1A1A1A" Foreground="#888"
                                FontWeight="SemiBold" Cursor="Hand"
                                Click="ConsoleTab_Click"/>
                            <Button x:Name="ProcessSelectBtn" ToolTip="Choose Roblox process"
                                Style="{StaticResource GlowButtonStyle}" Margin="20,0,0,0"
                                Click="ProcessSelect_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="Desktop" Width="14" Height="14"/>
                                    <TextBlock x:Name="SelectedPidTxt" Text="No PID" Margin="6,0,0,0" FontSize="11"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="ConnectionStatusTxt" Text="Disconnected"
                                   Foreground="#888" FontSize="11" Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Editor / Console / Theme panels — Row 1 fills remaining space -->
                    <Grid Grid.Row="1">
                        <Popup x:Name="SuggestionPopup"
                               PlacementTarget="{Binding ElementName=CodeEditor}"
                               Placement="RelativePoint"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Slide">
                            <Border Background="#12141D" BorderBrush="#050607" BorderThickness="1" CornerRadius="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="280"/>
                                    </Grid.ColumnDefinitions>
                                    <ListBox x:Name="SuggestionListBox" Grid.Column="0"
                                             Background="#14161F" Foreground="#F0F0F0" BorderThickness="0"
                                             FontFamily="Consolas" FontSize="15" MinHeight="120" MinWidth="250"
                                             SelectionChanged="SuggestionListBox_SelectionChanged"
                                             MouseDoubleClick="SuggestionListBox_MouseDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="6,3">
                                                    <fa:IconBlock Icon="Cube" Width="12" Height="12" Foreground="#B367FF" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Border Grid.Column="1" Background="#0F1118" BorderBrush="#050607" BorderThickness="1,0,0,0" Padding="10,8">
                                        <StackPanel>
                                            <TextBlock x:Name="SuggestionSignatureText" Foreground="#DDE4F8" FontFamily="Consolas" FontSize="13" Text="" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SuggestionDescriptionText" Foreground="#C7D4EA" FontSize="12" Margin="0,8,0,8" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SuggestionDocsLink" Text="Open Documentation" Foreground="#63A5FF" Cursor="Hand" TextDecorations="Underline" MouseLeftButtonUp="SuggestionDocsLink_MouseLeftButtonUp"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Popup>

                        <!-- Editor Panel -->
                        <Border x:Name="EditorPanel" CornerRadius="18" Margin="10,6,10,12" BorderBrush="#725595C4" BorderThickness="1.2">
                            <Border.Background>
                                <StaticResource ResourceKey="EditorAnimatedBackgroundBrush"/>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#6A2CB6" BlurRadius="20" ShadowDepth="0" Opacity="0.42"/>
                            </Border.Effect>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Background.(LinearGradientBrush.GradientStops)[0].Offset"
                                                             From="-0.15" To="0.35" Duration="0:0:8"/>
                                            <DoubleAnimation Storyboard.TargetProperty="Background.(LinearGradientBrush.GradientStops)[1].Offset"
                                                             From="0.3" To="0.8" Duration="0:0:8"/>
                                            <DoubleAnimation Storyboard.TargetProperty="Background.(LinearGradientBrush.GradientStops)[2].Offset"
                                                             From="0.9" To="1.15" Duration="0:0:8"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="8,6,8,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#2A1A45" CornerRadius="10" Padding="8,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="PinnedScopeText" Text="Scope: Global"
                                                       Foreground="#DCCBFF" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/>
                                            <Button Grid.Column="1" Content="+ Tab" Margin="8,0,0,0" Padding="8,2"
                                                    Style="{StaticResource GlowButtonStyle}" Click="AddEditorTab_Click"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                        <ScrollViewer x:Name="EditorTabsScrollViewer"
                                                      HorizontalScrollBarVisibility="Hidden"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      ScrollChanged="EditorTabsScrollViewer_ScrollChanged">
                                            <ItemsControl x:Name="EditorTabsList">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                                                            <Button Content="{Binding Title}" Padding="10,3" Click="EditorTabItem_Click" Tag="{Binding}" Style="{StaticResource GlowButtonStyle}"/>
                                                            <Button Content="×" Width="24" Margin="4,0,0,0" Click="CloseEditorTab_Click" Tag="{Binding}" Style="{StaticResource GlowButtonStyle}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Slider x:Name="EditorTabsSlider" Minimum="0" Maximum="0" Value="0"
                                                Margin="0,5,0,0" Height="16"
                                                ValueChanged="EditorTabsSlider_ValueChanged"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#3010152A" BorderBrush="#443A4A71" BorderThickness="0,0,1,0">
                                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
                                            <TextBlock x:Name="LineNumbersText"
                                                   Foreground="#6E84B4"
                                                   FontFamily="Consolas"
                                                   FontSize="13"
                                                   TextAlignment="Right"
                                                   Padding="0,10,16,0"
                                                   Text="1"/>
                                        </ScrollViewer>
                                    </Border>

                                    
                                    <Grid Grid.Column="1" HorizontalAlignment="Stretch" TextOptions.TextFormattingMode="Display">
                                        <!-- 1. Syntax Overlay (colored text, read-only) -->
                                        <RichTextBox x:Name="SyntaxOverlay"
                                                 IsReadOnly="True"
                                                 IsHitTestVisible="False"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Margin="12,10,12,10"
                                                 Padding="0"
                                                 FontFamily="Consolas"
                                                 FontSize="13"
                                                 VerticalScrollBarVisibility="Hidden"
                                                 HorizontalScrollBarVisibility="Hidden">
                                            <RichTextBox.Template>
                                                <ControlTemplate TargetType="RichTextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost" Padding="0" Margin="0"/>
                                                </ControlTemplate>
                                            </RichTextBox.Template>
                                        </RichTextBox>

                                        <!-- 2. (user types here) -->
                                        <TextBox x:Name="CodeEditor"
                                             Background="Transparent"
                                             Foreground="Transparent"
                                             CaretBrush="Transparent" 
                                             SelectionBrush="#5050A0FF"
                                             BorderThickness="0"
                                             Margin="12,10,12,10"
                                             Padding="0"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextChanged="CodeEditor_TextChanged"
                                             Loaded="CodeEditor_Loaded"
                                             SelectionChanged="CodeEditor_SelectionChanged"
                                             PreviewTextInput="CodeEditor_PreviewTextInput"
                                             PreviewKeyDown="CodeEditor_PreviewKeyDown">
                                            <TextBox.Template>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost" Padding="0" Margin="0"/>
                                                </ControlTemplate>
                                            </TextBox.Template>
                                        </TextBox>

                                    
                                        <!-- Tab Guides Canvas -->
                                        <Canvas x:Name="TabGuideCanvas" Panel.ZIndex="1">
                                            <!-- Will be populated in code -->
                                        </Canvas>
                                        <Canvas>
                                            <Rectangle x:Name="CaretOverlay"
                                               Fill="#ffffff"
                                               Width="1"
                                               Visibility="Collapsed"
                                               Panel.ZIndex="100"/>
                                        </Canvas>
                                    </Grid>

                                    <Border Grid.Column="2" Margin="6,0,6,0" Background="#20172634" CornerRadius="8" BorderBrush="#4D5B73A6" BorderThickness="1">
                                        <TextBox x:Name="MiniMapPreview"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             Foreground="#8EA0C7"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="5.8"
                                             TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Hidden"
                                             HorizontalScrollBarVisibility="Hidden"
                                             IsHitTestVisible="False"
                                             Padding="3,4"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Theme Panel -->
                        <Border x:Name="ThemePanel" Margin="10,6,10,12" Visibility="Collapsed"
                                Background="#D0101220" CornerRadius="18" BorderBrush="#5A607FA6" BorderThickness="1">
                            <StackPanel Margin="16">
                                <TextBlock Text="General" Foreground="#E6E6FF" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Reset State" Foreground="#DDE9FF" FontWeight="SemiBold"/><TextBlock Text="Resets local app settings and temporary state." Foreground="#8E9AB8" FontSize="11"/></StackPanel><Button Grid.Column="1" Content="Reset" Width="80" Style="{StaticResource GlowButtonStyle}" Click="GeneralAction_Click" Tag="reset-state"/></Grid>
                                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Reset Hardware ID" Foreground="#DDE9FF" FontWeight="SemiBold"/><TextBlock Text="Calls Syn-Z API reset HWID helper." Foreground="#8E9AB8" FontSize="11"/></StackPanel><Button Grid.Column="1" Content="Reset" Width="80" Style="{StaticResource GlowButtonStyle}" Click="GeneralAction_Click" Tag="reset-hwid"/></Grid>
                                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Create autoexec/workspace shortcuts" Foreground="#DDE9FF" FontWeight="SemiBold"/><TextBlock Text="Creates shortcut folders in app directory." Foreground="#8E9AB8" FontSize="11"/></StackPanel><Button Grid.Column="1" Content="Create" Width="80" Style="{StaticResource GlowButtonStyle}" Click="GeneralAction_Click" Tag="create-shortcuts"/></Grid>
                                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Toggle topmost" Foreground="#DDE9FF" FontWeight="SemiBold"/><TextBlock Text="Enable or disable always-on-top mode." Foreground="#8E9AB8" FontSize="11"/></StackPanel><Button x:Name="TopmostBtn" Grid.Column="1" Content="Enable" Width="80" Style="{StaticResource GlowButtonStyle}" Click="GeneralAction_Click" Tag="toggle-topmost"/></Grid>
                                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Open UI folder" Foreground="#DDE9FF" FontWeight="SemiBold"/><TextBlock Text="Open folder containing UI files and scripts." Foreground="#8E9AB8" FontSize="11"/></StackPanel><Button Grid.Column="1" Content="Open" Width="80" Style="{StaticResource GlowButtonStyle}" Click="GeneralAction_Click" Tag="open-ui-folder"/></Grid>
                                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Open Synapse Z folder" Foreground="#9EC0FF" FontWeight="SemiBold"/><TextBlock Text="Open folder containing Synapse Z files." Foreground="#8E9AB8" FontSize="11"/></StackPanel><Button Grid.Column="1" Content="Open" Width="80" Style="{StaticResource GlowButtonStyle}" Click="GeneralAction_Click" Tag="open-synz-folder"/></Grid>
                                <TextBlock x:Name="SyntaxStatusText" Visibility="Collapsed" Text="Syntax status: Ready"/>
                            </StackPanel>
                        </Border>

                        <!-- Console Panel -->
                        <Border Margin="10,6,10,12" CornerRadius="18" BorderBrush="#6577A6D1" BorderThickness="1.1"
                                Visibility="{Binding Visibility, ElementName=ConsoleOutput}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#111726" Offset="0"/>
                                    <GradientStop Color="#16122B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <RichTextBox x:Name="ConsoleOutput"
                                         Background="Transparent" Foreground="#DDE9FF"
                                         BorderThickness="0"
                                         FontFamily="Consolas" FontSize="12"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="15,10"
                                         Visibility="Collapsed"/>
                        </Border>

                        <!-- Floating action bar -->
                        <Border Background="#CC101522"
                                CornerRadius="16" Padding="10,6"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                Margin="0,0,0,12" MaxWidth="300"
                                Panel.ZIndex="10">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" ShadowDepth="0" BlurRadius="10" Opacity="0.6"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Trash" Margin="3" Click="ClearEditor_Click">
                                    <fa:IconBlock Icon="Trash" Width="16" Height="16"/>
                                </Button>
                                <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Clear Console" Margin="3" Click="ClearConsole_Click">
                                    <fa:IconBlock Icon="Eraser" Width="16" Height="16"/>
                                </Button>
                                <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Edit" Margin="3" Click="FormatEditor_Click">
                                    <fa:IconBlock Icon="Edit" Width="16" Height="16"/>
                                </Button>
                                <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Copy" Margin="3" Click="CopyEditor_Click">
                                    <fa:IconBlock Icon="Copy" Width="16" Height="16"/>
                                </Button>
                                <Button x:Name="LaunchRobloxBtn" Style="{StaticResource GlowButtonStyle}" ToolTip="Launch Roblox"
                                        Margin="5,3,3,3" Click="LaunchRoblox_Click">
                                    <fa:IconBlock Icon="Rocket" Width="18" Height="18" Foreground="#8BD3FF"/>
                                </Button>
                                <Button Style="{StaticResource GlowButtonStyle}" ToolTip="Execute"
                                        Margin="5,3,3,3" Click="ExecuteScript_Click">
                                    <fa:IconBlock Icon="Play" Width="18" Height="18" Foreground="{StaticResource AccentGreen}"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- RIGHT FLOATING TABS -->
                <StackPanel Grid.Column="2" Margin="14,120,12,0" VerticalAlignment="Top">
                    <Border Background="#C0080B17" CornerRadius="16" Padding="8" BorderBrush="#553A3F65" BorderThickness="1" Width="62">
                        <StackPanel>
                            <Button x:Name="EditorTabBtnRight" Style="{StaticResource GlowButtonStyle}" ToolTip="Editor" Margin="0,0,0,10" Width="44" Height="40" Click="EditorTab_Click">
                                <fa:IconBlock Icon="Code" Width="20" Height="20"/>
                            </Button>
                            <Button x:Name="ConsoleTabBtnRight" Style="{StaticResource GlowButtonStyle}" ToolTip="Console" Margin="0,0,0,10" Width="44" Height="40" Click="ConsoleTab_Click">
                                <fa:IconBlock Icon="Terminal" Width="20" Height="20"/>
                            </Button>
                            <Button x:Name="SettingsTabBtn" Style="{StaticResource GlowButtonStyle}" ToolTip="Theme Settings" Width="44" Height="40" Click="SettingsTab_Click">
                                <fa:IconBlock Icon="Gear" Width="20" Height="20"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Button x:Name="CloseButton" Style="{StaticResource CloseButtonStyle}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,15,15" Click="CloseButton_Click" Cursor="Hand">
            <fa:IconBlock Icon="Times" Width="20" Height="20" Foreground="White"/>
        </Button>
    </Grid>
</Window>
